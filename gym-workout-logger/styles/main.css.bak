/* ══════════════════════════════════════════
   DESIGN TOKENS
   — One accent color, used in 4 places only.
   — Everything else is black, white, and gray.
══════════════════════════════════════════ */
:root {
  --bg:        #080808;
  --surface:   #0f0f0f;
  --border:    rgba(255, 255, 255, 0.07);
  --border-md: rgba(255, 255, 255, 0.12);
  --accent:    #c9ff47;          /* electric lime — used sparingly */
  --text:      #f0f0f0;
  --muted:     #484848;
  --muted-2:   #2a2a2a;
  --success:   #4ade80;
  --danger:    #f87171;
  --warning:   #fbbf24;
  --nav-h:     60px;
  --radius:    0.75rem;
  --tr:        0.18s ease;
}

/* ══════════════════════════════════════════
   BASE
══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
  background-color: var(--bg);
  color: var(--text);
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  min-height: 100vh;
  padding-top: var(--nav-h);
  -webkit-font-smoothing: antialiased;
}

/* ══════════════════════════════════════════
   NAVBAR
══════════════════════════════════════════ */
.site-nav {
  height: var(--nav-h);
  background: rgba(8, 8, 8, 0.85) !important;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  z-index: 1000;
}

.navbar-brand {
  font-size: 1rem !important;
  font-weight: 700 !important;
  letter-spacing: -0.01em;
  color: var(--text) !important;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* The "W" mark — only place brand touches accent */
.brand-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  background: var(--accent);
  color: #000;
  font-size: 0.7rem;
  font-weight: 900;
  border-radius: 5px;
  letter-spacing: 0;
  flex-shrink: 0;
}

/* ══════════════════════════════════════════
   HERO  (index.html only)
   3-layer stack: video / overlay / content
══════════════════════════════════════════ */
.hero {
  position: relative;
  height: 54vh;
  min-height: 340px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-top: calc(-1 * var(--nav-h));
  padding-top: var(--nav-h);
}

/* Layer 0 — the video */
.hero__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
  filter: brightness(0.45) saturate(0.9);
}

/* Layer 1 — gradient overlay: transparent top, solid black bottom */
.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to bottom,
    rgba(8, 8, 8, 0.30) 0%,
    rgba(8, 8, 8, 0.65) 55%,
    rgba(8, 8, 8, 1.00) 100%
  );
}

/* Layer 2 — content */
.hero__content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 1rem;
}

.hero__eyebrow {
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  color: var(--accent);          /* accent use #1 */
  font-weight: 700;
  margin-bottom: 1rem;
}

.hero__title {
  font-size: clamp(2.6rem, 6vw, 4.8rem);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.04em;
  color: #fff;                   /* pure white — no gradient */
  margin-bottom: 2rem;
}

/* ══════════════════════════════════════════
   BUTTONS
══════════════════════════════════════════ */

/* Primary — white on black, clean inversion */
.btn-primary-custom {
  background: #fff;
  color: #000;
  border: none;
  border-radius: 0.55rem;
  padding: 0.65rem 1.5rem;
  font-weight: 700;
  font-size: 0.875rem;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  transition: opacity var(--tr), transform var(--tr);
  letter-spacing: -0.01em;
}
.btn-primary-custom:hover {
  opacity: 0.88;
  color: #000;
  transform: translateY(-1px);
}

/* Ghost — transparent with subtle border */
.btn-ghost {
  background: transparent;
  color: var(--muted);
  border: 1px solid var(--border-md);
  border-radius: 0.55rem;
  padding: 0.65rem 1.5rem;
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  transition: color var(--tr), border-color var(--tr), transform var(--tr);
  letter-spacing: -0.01em;
}
.btn-ghost:hover {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.25);
  transform: translateY(-1px);
}

/* Danger solid */
.btn-danger-solid {
  background: var(--danger);
  color: #fff;
  border: none;
  border-radius: 0.55rem;
  padding: 0.65rem 1.5rem;
  font-weight: 700;
  font-size: 0.875rem;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  transition: opacity var(--tr), transform var(--tr);
}
.btn-danger-solid:hover {
  opacity: 0.85;
  color: #fff;
  transform: translateY(-1px);
}

/* Danger ghost (Clear All) */
.btn-danger-ghost {
  background: transparent;
  color: var(--danger);
  border: 1px solid rgba(248, 113, 113, 0.2);
  border-radius: 0.55rem;
  padding: 0.65rem 1.5rem;
  font-weight: 600;
  font-size: 0.875rem;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  transition: background var(--tr), border-color var(--tr), transform var(--tr);
}
.btn-danger-ghost:hover {
  background: rgba(248, 113, 113, 0.08);
  border-color: rgba(248, 113, 113, 0.35);
  color: var(--danger);
  transform: translateY(-1px);
}

/* Bootstrap table action buttons override — no purple */
.btn-outline-primary {
  color: var(--text) !important;
  border-color: var(--border-md) !important;
  background: transparent !important;
  border-radius: 0.45rem !important;
  font-size: 0.78rem !important;
  font-weight: 600 !important;
  transition: all var(--tr) !important;
}
.btn-outline-primary:hover {
  background: rgba(255, 255, 255, 0.08) !important;
  border-color: rgba(255, 255, 255, 0.25) !important;
  color: #fff !important;
}

.btn-outline-danger {
  color: var(--danger) !important;
  border-color: rgba(248, 113, 113, 0.25) !important;
  background: transparent !important;
  border-radius: 0.45rem !important;
  font-size: 0.78rem !important;
  font-weight: 600 !important;
  transition: all var(--tr) !important;
}
.btn-outline-danger:hover {
  background: rgba(248, 113, 113, 0.1) !important;
  border-color: var(--danger) !important;
  color: var(--danger) !important;
}

/* ══════════════════════════════════════════
   TABLE SECTION
══════════════════════════════════════════ */
.section-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.section-label {
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--muted);
  font-weight: 700;
}

#table-wrapper {
  background: var(--surface);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  overflow: hidden;
}

/* Override Bootstrap 5 table variables — this is how BS5 controls cell backgrounds */
.table {
  --bs-table-bg:          var(--surface);
  --bs-table-color:       var(--text);
  --bs-table-border-color: var(--border);
  --bs-table-hover-bg:    rgba(255, 255, 255, 0.04);
  --bs-table-hover-color: #fff;
  --bs-table-striped-bg:  transparent;
  margin-bottom: 0;
}

.table thead th {
  background: var(--muted-2);
  color: var(--muted);
  font-size: 0.68rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-weight: 700;
  padding: 0.9rem 1.25rem;
  border-bottom: 1px solid var(--border);
  border-top: none;
  white-space: nowrap;
}

.table tbody tr {
  transition: background var(--tr);
}

.table tbody td {
  padding: 1rem 1.25rem;
  vertical-align: middle;
  font-size: 0.88rem;
  color: var(--text);
}

.table tbody td:first-child {
  font-weight: 600;
  color: #fff;
}

/* Volume — accent use #2 */
.volume-cell {
  font-weight: 700;
  color: var(--accent) !important;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.01em;
}

/* ══════════════════════════════════════════
   VS LAST SESSION BADGES
══════════════════════════════════════════ */
.vs-badge {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.01em;
}

.text-success   { color: var(--success) !important; }
.text-danger    { color: var(--danger)  !important; }
.text-secondary { color: var(--muted)   !important; }
/* First Entry — accent use #3 */
.text-primary   { color: var(--accent)  !important; }

/* ══════════════════════════════════════════
   EMPTY STATE
══════════════════════════════════════════ */
.empty-state {
  padding: 5rem 1rem;
  text-align: center;
}

.empty-state p {
  font-size: 0.95rem;
  line-height: 1.8;
  color: var(--muted);
  max-width: 300px;
  margin: 0 auto;
}

/* ══════════════════════════════════════════
   DARK CARD  (forms & delete pages)
══════════════════════════════════════════ */
.dark-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}

.dark-card__header {
  padding: 1.1rem 1.75rem;
  border-bottom: 1px solid var(--border);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--muted);
}

.dark-card__body {
  padding: 1.75rem;
}

/* ══════════════════════════════════════════
   FORM INPUTS
══════════════════════════════════════════ */
.form-label {
  color: var(--muted);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.4rem;
}

.form-control {
  background: #111 !important;
  border: 1px solid var(--border-md) !important;
  color: var(--text) !important;
  border-radius: 0.5rem !important;
  padding: 0.65rem 0.9rem !important;
  font-size: 0.9rem !important;
  transition: border-color var(--tr), box-shadow var(--tr) !important;
}

.form-control:focus {
  background: #141414 !important;
  border-color: rgba(255, 255, 255, 0.35) !important;
  box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.05) !important;
  color: var(--text) !important;
  outline: none !important;
}

.form-control::placeholder {
  color: var(--muted) !important;
}

input[type="date"]::-webkit-calendar-picker-indicator {
  filter: invert(0.4);
  cursor: pointer;
}

.form-control.is-invalid,
.was-validated .form-control:invalid {
  border-color: var(--danger) !important;
  box-shadow: none !important;
}
.form-control.is-invalid:focus,
.was-validated .form-control:invalid:focus {
  box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.15) !important;
}

.invalid-feedback {
  color: var(--danger);
  font-size: 0.78rem;
  margin-top: 0.3rem;
}

/* ══════════════════════════════════════════
   DELETE DETAIL ROWS
══════════════════════════════════════════ */
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--border);
}

.detail-row:last-child { border-bottom: none; }

.detail-label {
  color: var(--muted);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
}

.detail-value {
  font-weight: 600;
  color: var(--text);
  font-size: 0.9rem;
}

/* Volume in delete card — accent use #4 */
.detail-value.is-volume {
  color: var(--accent);
  font-weight: 700;
}

.delete-warning {
  font-size: 0.85rem;
  color: var(--muted);
  margin-bottom: 1.5rem;
  line-height: 1.7;
}

/* ══════════════════════════════════════════
   ALERT
══════════════════════════════════════════ */
.alert-warning {
  background: rgba(251, 191, 36, 0.08) !important;
  border-color: rgba(251, 191, 36, 0.2) !important;
  color: var(--warning) !important;
  border-radius: var(--radius) !important;
  font-size: 0.9rem;
}
.alert-warning .alert-link {
  color: #fff !important;
  font-weight: 700;
}

/* ══════════════════════════════════════════
   PAGE HEADER (inner pages)
══════════════════════════════════════════ */
.page-header {
  padding: 2.25rem 0 1.5rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 2rem;
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  color: var(--muted);
  font-size: 0.72rem;
  font-weight: 700;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 0.6rem;
  transition: color var(--tr);
}
.back-link:hover { color: var(--text); }

.page-header h1 {
  font-size: 1.75rem;
  font-weight: 800;
  letter-spacing: -0.035em;
  color: #fff;
  margin: 0;
  line-height: 1;
}

/* ══════════════════════════════════════════
   ANIMATIONS
═════════════════════════════════════ */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

.fade-in            { animation: fadeUp 0.4s ease forwards; }
.fade-in-d1         { opacity: 0; animation: fadeUp 0.4s 0.08s ease forwards; }
.fade-in-d2         { opacity: 0; animation: fadeUp 0.4s 0.16s ease forwards; }
